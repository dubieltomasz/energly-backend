{
  "name": "energly-backend",
  "version": "1.0.0",
  "description": "Backend for an application that displays the UK energy mix and calculates the optimal time window for charging an electric vehicle to maximize the share of clean energy.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dubieltomasz/energly-backend.git"
  },
  "author": "Tomasz Dubiel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dubieltomasz/energly-backend/issues"
  },
  "homepage": "https://github.com/dubieltomasz/energly-backend#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "node-fetch": "^3.3.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
